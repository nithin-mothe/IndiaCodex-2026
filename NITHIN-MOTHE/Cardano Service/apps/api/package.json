{
  "name": "@trustpay/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "prisma generate --schema ../../database/schema.prisma && tsc --build",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint . --max-warnings=0",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --build --pretty"
  },
  "prisma": {
    "schema": "../../database/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.12.0",
    "@trustpay/config": "0.1.0",
    "@trustpay/types": "0.1.0",
    "@trustpay/utils": "0.1.0",
    "bullmq": "^5.56.0",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0"
  }
}
